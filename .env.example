NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mini_mart_pos
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Feature Flags
FF_AUTH=true
FF_CATEGORIES=false
FF_UNIT_TYPES=false
FF_SUPPLIERS=false
FF_PRODUCTS=false
FF_CUSTOMERS=false
FF_SALES=false
FF_PURCHASES=false
FF_EXPENSES=false
FF_DASHBOARD=false
FF_USERS=false
FF_REPORTS=false

# CORS
CORS_ORIGIN=http://localhost:3000

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100
